{
  "name": "@gist-command-logger/cli",
  "version": "0.2.0",
  "description": "Cross-platform shell command logger that uploads filtered events to GitHub Gist",
  "type": "module",
  "bin": {
    "gist-command-logger": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target=node --outdir dist --sourcemap",
    "dev": "bun run src/cli.ts",
    "test": "bun test tests/*.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "bun-types": "^1.2.15"
  },
  "keywords": [
    "gist",
    "shell",
    "cli",
    "zsh",
    "bash",
    "logging"
  ],
  "license": "MIT"
}
